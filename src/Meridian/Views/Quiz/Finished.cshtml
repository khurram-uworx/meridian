@model Uworx.Meridian.Entities.QuizAttempt
@{
    ViewData["Title"] = "Quiz Finished";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0 text-center">Quiz Completed!</h4>
                </div>
                <div class="card-body text-center">
                    <h1 class="display-1">@Model.Score / @Model.MaxScore</h1>
                    <p class="lead">Your score has been posted as a comment on the Jira story and the ticket has been transitioned to <strong>In Review</strong>.</p>
                    <hr />
                    <p>You can now return to your Jira board to continue with the next sections.</p>
                </div>
            </div>
        </div>
    </div>
</div>
